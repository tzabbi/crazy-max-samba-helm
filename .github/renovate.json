{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticPrefixChore",
    ":label(dependencies)",
    ":disableRateLimiting"
  ],
  "automergeType": "branch",
  "commitMessagePrefix": "chore: ",
  "packageRules": [
    {
      "description": "Automerge patch",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    },
    {
      "description": "No automerge for minor and major updates",
      "matchUpdateTypes": [
        "minor",
        "major"
      ],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "fileMatch": ["^Chart.yaml$", "^charts/.+/Chart.yaml$"],
      "matchStrings": ["appVersion:\\s?\"?(?<currentValue>.*?)\"?$"],
      "depNameTemplate": "crazy-max-samba",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker",
      "packageNameTemplate": "ghcr.io/crazy-max/samba"
    }
  ]
}
